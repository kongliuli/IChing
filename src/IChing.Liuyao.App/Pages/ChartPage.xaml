<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.Liuyao.App.Pages.ChartPage"
             Title="六爻起卦"
             Background="{StaticResource PageGradient}">

    <ScrollView x:Name="MainScroll">
        <VerticalStackLayout Padding="20,28" Spacing="18">
            <VerticalStackLayout Spacing="6">
                <Label Text="六爻起卦"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Gold}" />
                <Label Text="铜钱 / 时间卦 · 纳甲六亲"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <Border Stroke="{StaticResource GoldDim}" StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}" Padding="16"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="起卦方式" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <Picker x:Name="MethodPicker" SelectedIndexChanged="OnMethodChanged">
                        <Picker.Items>
                            <x:String>铜钱法</x:String>
                            <x:String>时间卦</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label Text="时间" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <DatePicker x:Name="CastDate" TextColor="{StaticResource TextPrimary}" />
                    <TimePicker x:Name="CastTime" TextColor="{StaticResource TextPrimary}" />

                    <VerticalStackLayout x:Name="SeedPanel" Spacing="4">
                        <Label Text="随机种子（可选）" TextColor="{StaticResource Muted}" FontSize="12" />
                        <Entry x:Name="SeedEntry"
                               Keyboard="Numeric"
                               Placeholder="42"
                               Text="42"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="{StaticResource SurfaceAlt}" />
                    </VerticalStackLayout>

                    <Label Text="问题" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <Entry x:Name="QuestionEntry"
                           Placeholder="这件事的发展如何？"
                           TextColor="{StaticResource TextPrimary}"
                           BackgroundColor="{StaticResource SurfaceAlt}" />

                    <Button x:Name="CastButton"
                            Text="起卦"
                            Clicked="OnCastClicked"
                            BackgroundColor="{StaticResource Gold}"
                            TextColor="{StaticResource Black}" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ResultPanel"
                    IsVisible="False"
                    Stroke="{StaticResource GoldDim}" StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}" Padding="16"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="HexagramLabel"
                           TextColor="{StaticResource Gold}"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <VerticalStackLayout x:Name="LinesHost" Spacing="4" />

                    <HorizontalStackLayout Spacing="10">
                        <Button x:Name="Tier0Button"
                                Text="概览解读"
                                Clicked="OnTier0Clicked"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                TextColor="{StaticResource TextPrimary}" />
                        <Button x:Name="Tier1Button"
                                Text="AI 解读"
                                Clicked="OnTier1Clicked"
                                BackgroundColor="{StaticResource Gold}"
                                TextColor="{StaticResource Black}" />
                    </HorizontalStackLayout>

                    <ActivityIndicator x:Name="InterpretBusy" IsVisible="False" IsRunning="False" Color="{StaticResource Gold}" />
                    <Label x:Name="SummaryLabel"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="ErrorLabel"
                   IsVisible="False"
                   TextColor="{StaticResource Danger}"
                   FontSize="13" />

            <Border x:Name="HistoryPanel"
                    IsVisible="False"
                    Stroke="{StaticResource GoldDim}" StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}" Padding="16"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="8">
                    <HorizontalStackLayout>
                        <Label Text="最近起卦" TextColor="{StaticResource Gold}" FontAttributes="Bold" HorizontalOptions="FillAndExpand" />
                        <Button Text="清空" Clicked="OnClearHistoryClicked" FontSize="12" BackgroundColor="Transparent" TextColor="{StaticResource Muted}" />
                    </HorizontalStackLayout>
                    <VerticalStackLayout x:Name="HistoryHost" Spacing="6" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
