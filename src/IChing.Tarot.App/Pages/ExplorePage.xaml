<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"

             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

             x:Class="IChing.Tarot.App.Pages.ExplorePage"

             Title="探索"

             Background="{StaticResource PageGradient}">



    <ScrollView>

        <VerticalStackLayout x:Name="RootStack" Padding="20,28" Spacing="18">

            <Label x:Name="HeaderTitleLabel"

                   FontSize="26"

                   FontAttributes="Bold"

                   TextColor="{StaticResource Gold}" />

            <Label x:Name="HeaderSubtitleLabel"

                   TextColor="{StaticResource TextSecondary}"

                   FontSize="14"

                   LineBreakMode="WordWrap" />

            <VerticalStackLayout x:Name="ModulesHost" Spacing="18" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>

