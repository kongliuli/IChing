<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.App.Pages.HistoryPage"
             Title="历史">
    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,32"
                             Spacing="14"
                             MaximumWidthRequest="760"
                             HorizontalOptions="Fill">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="历史"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Ink}" />
                    <Label Text="本地记录"
                           FontSize="12"
                           TextColor="{StaticResource Cinnabar}" />
                    <BoxView HeightRequest="2"
                             WidthRequest="48"
                             HorizontalOptions="Start"
                             Color="{StaticResource Cinnabar}" />
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="清空"
                        Clicked="OnClearClicked"
                        TextColor="{StaticResource Jade}"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        BorderColor="{StaticResource StrokeSoft}"
                        BorderWidth="1" />
            </Grid>

            <Border x:Name="EmptyLabel"
                    Padding="18"
                    BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource StrokeSoft}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8">
                <Label Text="还没有记录。"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource Muted}" />
            </Border>

            <CollectionView x:Name="HistoryView"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10"
                                Padding="12"
                                BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource StrokeSoft}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding DisplayLine}"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Summary}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding Interpretation}"
                                       FontSize="12"
                                       TextColor="{StaticResource Jade}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
