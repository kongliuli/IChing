<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:IChing.App.Pages"
       x:Class="IChing.App.AppShell"
       FlyoutBehavior="Disabled"
       BackgroundColor="{StaticResource Background}"
       ForegroundColor="{StaticResource TextPrimary}"
       TitleColor="{StaticResource Gold}">
    <TabBar>
        <ShellContent Title="八字"
                      ContentTemplate="{DataTemplate pages:BaziPage}" />
        <ShellContent Title="六爻"
                      ContentTemplate="{DataTemplate pages:LiuyaoPage}" />
        <ShellContent Title="历史"
                      ContentTemplate="{DataTemplate pages:HistoryPage}" />
        <ShellContent Title="设置"
                      ContentTemplate="{DataTemplate pages:SettingsPage}" />
    </TabBar>
</Shell>
