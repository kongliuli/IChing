<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:IChing.Tarot.App.Models"
             x:Class="IChing.Tarot.App.Pages.HistoryDetailPage"
             Title="历史详情"
             Background="{StaticResource PageGradient}">

    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="14">
            <Label x:Name="TitleLabel"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{StaticResource PurpleLight}" />
            <Label x:Name="MetaLabel"
                   FontSize="12"
                   TextColor="{StaticResource TextSecondary}" />

            <Grid x:Name="CelticCrossHost" IsVisible="False" />

            <CollectionView x:Name="CardsCollection" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:CardDisplayItem">
                        <Border Margin="0,0,0,10"
                                Padding="12"
                                Background="{StaticResource Surface}"
                                Stroke="{StaticResource GoldDim}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding PositionTitle}"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Gold}" />
                                <Label Text="{Binding CardLine}"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Meaning}"
                                       FontSize="13"
                                       LineBreakMode="WordWrap"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
