<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.Tarot.App.Pages.HistoryDetailPage"
             Title="历史详情"
             Background="{StaticResource PageGradient}">

    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="14">
            <Label x:Name="TitleLabel"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{StaticResource PurpleLight}" />
            <Label x:Name="MetaLabel"
                   FontSize="12"
                   TextColor="{StaticResource TextSecondary}" />

            <Grid x:Name="SpreadBoardHost"
                  ColumnDefinitions="*"
                  RowDefinitions="Auto"
                  ColumnSpacing="8"
                  RowSpacing="8" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
