<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.App.Pages.BaziPage"
             Title="八字">
    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,32"
                             Spacing="14"
                             MaximumWidthRequest="760"
                             HorizontalOptions="Fill">
            <VerticalStackLayout Spacing="4">
                <Label Text="八字"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Ink}" />
                <Label Text="乾 坤 震 巽 坎 离 艮 兑"
                       FontSize="12"
                       TextColor="{StaticResource Cinnabar}" />
                <BoxView HeightRequest="2"
                         WidthRequest="48"
                         HorizontalOptions="Start"
                         Color="{StaticResource Cinnabar}" />
            </VerticalStackLayout>

            <Border Stroke="{StaticResource StrokeSoft}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}"
                    Padding="14"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="10">
                    <Label Text="出生信息"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Jade}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Entry x:Name="YearEntry" Text="1990" Placeholder="年" Keyboard="Numeric" />
                        <Entry x:Name="MonthEntry" Grid.Column="1" Text="5" Placeholder="月" Keyboard="Numeric" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Entry x:Name="DayEntry" Text="20" Placeholder="日" Keyboard="Numeric" />
                        <Entry x:Name="HourEntry" Grid.Column="1" Text="10" Placeholder="时" Keyboard="Numeric" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Entry x:Name="MinuteEntry" Text="0" Placeholder="分" Keyboard="Numeric" />
                        <Picker x:Name="GenderPicker" Grid.Column="1" Title="性别">
                            <Picker.Items>
                                <x:String>女</x:String>
                                <x:String>男</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Entry x:Name="CityEntry" Placeholder="城市，可空" />
                        <Entry x:Name="LongitudeEntry" Grid.Column="1" Placeholder="经度，可空" Keyboard="Numeric" />
                    </Grid>
                    <Entry x:Name="FocusEntry" Text="事业" Placeholder="关注点" />
                    <Button Text="排盘"
                            Clicked="OnCalculateClicked"
                            TextColor="{StaticResource White}"
                            BackgroundColor="{StaticResource Cinnabar}" />
                    <Label x:Name="ErrorLabel"
                           IsVisible="False"
                           FontSize="12"
                           TextColor="{StaticResource Danger}" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ResultPanel"
                    IsVisible="False"
                    Stroke="{StaticResource StrokeSoft}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource SurfaceRaised}"
                    Padding="14"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="BaziTitleLabel"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Cinnabar}" />
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                        <Border Padding="8" BackgroundColor="{StaticResource SurfaceAlt}" Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="年柱" FontSize="11" TextColor="{StaticResource Muted}" />
                                <Label x:Name="YearPillarLabel" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Padding="8" BackgroundColor="{StaticResource SurfaceAlt}" Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="月柱" FontSize="11" TextColor="{StaticResource Muted}" />
                                <Label x:Name="MonthPillarLabel" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" Padding="8" BackgroundColor="{StaticResource SurfaceAlt}" Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="日柱" FontSize="11" TextColor="{StaticResource Muted}" />
                                <Label x:Name="DayPillarLabel" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="3" Padding="8" BackgroundColor="{StaticResource SurfaceAlt}" Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="时柱" FontSize="11" TextColor="{StaticResource Muted}" />
                                <Label x:Name="HourPillarLabel" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                    <Label x:Name="BaziSummaryLabel"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}" />
                    <BoxView HeightRequest="1" Color="{StaticResource StrokeSoft}" />
                    <Label x:Name="YongshenLabel"
                           FontSize="14"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="DaYunLabel"
                           FontSize="12"
                           TextColor="{StaticResource Muted}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Button x:Name="InterpretButton"
                                Text="AI 解读"
                                IsEnabled="False"
                                Clicked="OnInterpretClicked"
                                TextColor="{StaticResource White}"
                                BackgroundColor="{StaticResource Jade}" />
                        <ActivityIndicator x:Name="InterpretIndicator"
                                           Grid.Column="1"
                                           IsRunning="False"
                                           IsVisible="False"
                                           Color="{StaticResource Jade}" />
                    </Grid>
                    <Border x:Name="InterpretationPanel"
                            IsVisible="False"
                            Padding="12"
                            BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource StrokeSoft}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <Label x:Name="InterpretStatusLabel"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Muted}"
                                       VerticalOptions="Center" />
                                <Button x:Name="ExportButton"
                                        Grid.Column="1"
                                        Text="导出图片"
                                        IsVisible="False"
                                        Clicked="OnExportClicked"
                                        TextColor="{StaticResource White}"
                                        BackgroundColor="{StaticResource Cinnabar}" />
                            </Grid>
                            <Label x:Name="InterpretationLabel"
                                   FontSize="13"
                                   TextColor="{StaticResource TextPrimary}" />
                            <WebView x:Name="ReadingWebView"
                                     IsVisible="False"
                                     HeightRequest="760" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
