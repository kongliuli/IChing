<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.Tarot.App.Pages.ElementQuizPage"
             Title="四元素倾向"
             Shell.NavBarIsVisible="True"
             Shell.TabBarIsVisible="False"
             Background="{StaticResource PageGradient}">

    <ScrollView x:Name="MainScroll">
        <VerticalStackLayout Padding="22,26,22,34"
                             Spacing="18"
                             MaximumWidthRequest="820"
                             HorizontalOptions="Center">
            <VerticalStackLayout Spacing="5">
                <Label Text="四元素倾向测试" Style="{StaticResource PageTitle}" />
                <Label x:Name="ProgressLabel" Style="{StaticResource PageKicker}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource TarotCardPanel}">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="QuestionLabel"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           LineBreakMode="WordWrap" />
                    <VerticalStackLayout x:Name="OptionsHost" Spacing="8" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ResultPanel"
                    IsVisible="False"
                    Style="{StaticResource TarotCardPanel}">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="ResultTitleLabel"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PurpleLight}" />
                    <Label x:Name="ResultSummaryLabel"
                           FontSize="14"
                           TextColor="{StaticResource TextPrimary}"
                           LineBreakMode="WordWrap" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="保存长图"
                                Clicked="OnSaveImageClicked"
                                Style="{StaticResource OutlineButton}" />
                        <Button Grid.Column="1"
                                Text="重新测试"
                                Clicked="OnRestartClicked"
                                Style="{StaticResource GoldButton}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
