<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:IChing.Tarot.App.Models"
             xmlns:services="clr-namespace:IChing.Tarot.App.Services"
             x:Class="IChing.Tarot.App.Pages.DrawPage"
             Title="星轨塔罗"
             Background="{StaticResource PageGradient}">

    <ScrollView x:Name="MainScroll">
        <VerticalStackLayout Padding="20,28" Spacing="18">

            <VerticalStackLayout Spacing="6">
                <Label Text="星轨塔罗"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Gold}" />
                <Label Text="静心提问 · 本地抽牌 · AI 深度解读"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <Border Stroke="{StaticResource GoldDim}"
                    StrokeThickness="1"
                    Background="{StaticResource Surface}"
                    Padding="16"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="你的问题" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <Editor x:Name="QuestionEntry"
                            Placeholder="例如：接下来三个月的事业方向？"
                            PlaceholderColor="{StaticResource Muted}"
                            TextColor="{StaticResource TextPrimary}"
                            BackgroundColor="{StaticResource SurfaceAlt}"
                            AutoSize="TextChanges"
                            MinimumHeightRequest="72"
                            MaxLength="200" />

                    <Label Text="牌阵" TextColor="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,0" />
                    <Picker x:Name="SpreadPicker"
                            Title="选择牌阵"
                            TextColor="{StaticResource TextPrimary}"
                            BackgroundColor="{StaticResource SurfaceAlt}"
                            SelectedIndexChanged="OnSpreadChanged" />

                    <HorizontalStackLayout Spacing="8">
                        <Border Padding="6,2"
                                Background="{StaticResource SurfaceAlt}"
                                Stroke="{StaticResource GoldDim}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <Label x:Name="SpreadDifficultyLabel"
                                   FontSize="11"
                                   TextColor="{StaticResource Gold}" />
                        </Border>
                        <Label x:Name="SpreadDescriptionLabel"
                               TextColor="{StaticResource Muted}"
                               FontSize="12"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap"
                               HorizontalOptions="Fill" />
                    </HorizontalStackLayout>

                    <Expander IsExpanded="False">
                        <Expander.Header>
                            <Label Text="高级选项"
                                   TextColor="{StaticResource TextSecondary}"
                                   FontSize="12" />
                        </Expander.Header>
                        <VerticalStackLayout Spacing="4" Padding="0,8,0,0">
                            <Label Text="随机种子（留空则每次不同）"
                                   TextColor="{StaticResource Muted}" FontSize="12" />
                            <Entry x:Name="SeedEntry"
                                   Keyboard="Numeric"
                                   Placeholder="如 42"
                                   TextColor="{StaticResource TextPrimary}"
                                   BackgroundColor="{StaticResource SurfaceAlt}" />
                        </VerticalStackLayout>
                    </Expander>

                    <Button x:Name="DrawButton"
                            Text="✦  开始抽牌"
                            Clicked="OnDrawClicked"
                            TextColor="#1A1208"
                            FontAttributes="Bold"
                            FontSize="16"
                            Background="{StaticResource GoldButtonGradient}"
                            Padding="18,14"
                            CornerRadius="28"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="EmptyStatePanel"
                    Stroke="{StaticResource GoldDim}"
                    StrokeThickness="1"
                    Background="{StaticResource Surface}"
                    Padding="24,32"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="✦"
                           FontSize="36"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource GoldDim}" />
                    <Label Text="输入问题并选择牌阵，然后抽牌"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource Muted}"
                           FontSize="14" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ReadingPanel"
                    IsVisible="False"
                    Stroke="{StaticResource Purple}"
                    StrokeThickness="1"
                    Background="{StaticResource CardGradient}"
                    Padding="16"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="14">
                    <Label x:Name="ReadingTitleLabel"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PurpleLight}" />
                    <Label x:Name="ReadingMetaLabel"
                           FontSize="12"
                           TextColor="{StaticResource TextSecondary}" />

                    <CollectionView x:Name="CardsCollection" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:CardDisplayItem">
                                <Border Margin="0,0,0,10"
                                        Padding="0"
                                        Background="{StaticResource Surface}"
                                        Stroke="{StaticResource GoldDim}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 12">
                                    <Grid ColumnDefinitions="6,Auto,*" ColumnSpacing="0">
                                        <BoxView Grid.Column="0"
                                                 Color="{Binding SuitAccent}"
                                                 HorizontalOptions="Fill"
                                                 VerticalOptions="Fill" />
                                        <Border Grid.Column="1"
                                                Margin="12,12,0,12"
                                                WidthRequest="52"
                                                HeightRequest="78"
                                                BackgroundColor="{StaticResource SurfaceAlt}"
                                                Stroke="{Binding SuitAccent}"
                                                StrokeThickness="1.5"
                                                StrokeShape="RoundRectangle 8"
                                                Rotation="{Binding CardRotation}">
                                            <Grid>
                                                <Image Source="{Binding CardImage}"
                                                       Aspect="AspectFill"
                                                       IsVisible="{Binding HasImage}" />
                                                <VerticalStackLayout IsVisible="{Binding HasPlaceholder}"
                                                                     VerticalOptions="Center"
                                                                     HorizontalOptions="Center"
                                                                     Spacing="2">
                                                <Label Text="{Binding Abbrev}"
                                                       FontSize="18"
                                                       FontAttributes="Bold"
                                                       TextColor="{Binding SuitAccent}"
                                                       HorizontalOptions="Center" />
                                                <Label Text="✦"
                                                       FontSize="12"
                                                       TextColor="{StaticResource GoldDim}"
                                                       HorizontalOptions="Center" />
                                            </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="2"
                                                             Margin="12,12,14,12"
                                                             Spacing="4">
                                            <HorizontalStackLayout Spacing="8">
                                                <Label Text="{Binding PositionTitle}"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource Gold}"
                                                       VerticalOptions="Center" />
                                                <Border IsVisible="{Binding IsReversed}"
                                                        Padding="6,2"
                                                        BackgroundColor="#3A1F2A"
                                                        Stroke="{StaticResource Danger}"
                                                        StrokeThickness="1"
                                                        StrokeShape="RoundRectangle 6">
                                                    <Label Text="逆位"
                                                           FontSize="10"
                                                           TextColor="{StaticResource Danger}" />
                                                </Border>
                                            </HorizontalStackLayout>
                                            <Label Text="{Binding CardLine}"
                                                   TextColor="{StaticResource TextPrimary}" />
                                            <Label Text="{Binding Meaning}"
                                                   FontSize="13"
                                                   LineBreakMode="WordWrap"
                                                   TextColor="{StaticResource TextSecondary}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="AI 解读"
                                x:Name="InterpretButton"
                                Clicked="OnInterpretClicked"
                                IsEnabled="False"
                                TextColor="#1A1208"
                                FontAttributes="Bold"
                                Background="{StaticResource GoldButtonGradient}"
                                CornerRadius="24"
                                Padding="14,12" />
                        <Button Grid.Column="1"
                                Text="重新抽牌"
                                Clicked="OnRedrawClicked"
                                TextColor="{StaticResource Gold}"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                BorderColor="{StaticResource GoldDim}"
                                BorderWidth="1"
                                CornerRadius="24"
                                Padding="14,12" />
                    </Grid>

                    <ActivityIndicator x:Name="LoadingIndicator"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="{StaticResource Gold}" />

                    <Border x:Name="InterpretationPanel"
                            IsVisible="False"
                            Padding="14"
                            Background="{StaticResource SurfaceAlt}"
                            Stroke="{StaticResource PurpleLight}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="解读"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource PurpleLight}" />
                                <Button Grid.Column="1"
                                        Text="复制"
                                        FontSize="12"
                                        Padding="10,4"
                                        CornerRadius="12"
                                        Clicked="OnCopyInterpretationClicked"
                                        TextColor="{StaticResource Gold}"
                                        BackgroundColor="Transparent"
                                        BorderColor="{StaticResource GoldDim}"
                                        BorderWidth="1" />
                            </Grid>
                            <Label x:Name="InterpretationLabel"
                                   LineBreakMode="WordWrap"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label x:Name="InterpretationStatusLabel"
                                   FontSize="12"
                                   TextColor="{StaticResource Muted}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border x:Name="HistoryPanel"
                    IsVisible="False"
                    Stroke="{StaticResource GoldDim}"
                    StrokeThickness="1"
                    Background="{StaticResource Surface}"
                    Padding="16"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="最近抽牌（点击复现）"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gold}" />
                    <CollectionView x:Name="HistoryCollection"
                                    SelectionMode="Single"
                                    SelectionChanged="OnHistorySelected"
                                    HeightRequest="120">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="services:HistoryEntry">
                                <Label Text="{Binding DisplayLine}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}"
                                       Margin="0,0,0,6" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
