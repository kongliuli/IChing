<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.App.Pages.HistoryPage"
             Title="历史">
    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="16">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="历史记录"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Gold}" />
                <Button Grid.Column="1"
                        Text="清空"
                        Clicked="OnClearClicked"
                        TextColor="{StaticResource Gold}"
                        BackgroundColor="{StaticResource SurfaceAlt}"
                        BorderColor="{StaticResource StrokeSoft}"
                        BorderWidth="1" />
            </Grid>

            <Label x:Name="EmptyLabel"
                   Text="还没有记录。"
                   TextColor="{StaticResource Muted}" />

            <CollectionView x:Name="HistoryView"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10"
                                Padding="12"
                                BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource StrokeSoft}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding DisplayLine}"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Summary}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}"
                                       LineBreakMode="WordWrap" />
                                <Label Text="{Binding Interpretation}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gold}"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
