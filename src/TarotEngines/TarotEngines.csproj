<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- 进程内官方塔罗引擎：公共契约由主程序提供，避免 plugins/ 里出现重复副本。 -->
