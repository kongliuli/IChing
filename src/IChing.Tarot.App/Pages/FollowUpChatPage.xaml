<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.Tarot.App.Pages.FollowUpChatPage"
             Title="追问"
             Background="{StaticResource PageGradient}">
    <Grid RowDefinitions="*,Auto"
          Padding="16"
          RowSpacing="10">
        <ScrollView x:Name="ChatScroll">
            <VerticalStackLayout x:Name="ChatHost"
                                 Spacing="10"
                                 MaximumWidthRequest="860"
                                 HorizontalOptions="Center" />
        </ScrollView>
        <Border Grid.Row="1"
                Padding="10"
                MaximumWidthRequest="860"
                HorizontalOptions="Center"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource StrokeSoft}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry x:Name="QuestionEntry"
                       Placeholder="继续追问，最多三轮"
                       TextColor="{StaticResource TextPrimary}"
                       BackgroundColor="{StaticResource SurfaceAlt}" />
                <Button Grid.Column="1"
                        x:Name="SendButton"
                        Text="发送"
                        Clicked="OnSendClicked"
                        Style="{StaticResource GoldButton}" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
