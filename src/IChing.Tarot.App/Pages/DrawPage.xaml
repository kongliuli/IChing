<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:IChing.Tarot.App.Services"
             x:Class="IChing.Tarot.App.Pages.DrawPage"
             Title="星轨塔罗"
             Background="{StaticResource PageGradient}">

    <ScrollView x:Name="MainScroll">
        <VerticalStackLayout Padding="20,24" Spacing="16">

            <VerticalStackLayout Spacing="6">
                <Label Text="星轨塔罗"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Gold}" />
                <Label Text="静心提问 · 本地抽牌 · AI 深度解读"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <Border Stroke="{StaticResource StrokeSoft}"
                    StrokeThickness="1"
                    Background="{StaticResource CardGradient}"
                    Padding="18"
                    StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="你的问题" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <Editor x:Name="QuestionEntry"
                            Placeholder="例如：接下来三个月的事业方向？"
                            PlaceholderColor="{StaticResource Muted}"
                            TextColor="{StaticResource TextPrimary}"
                            BackgroundColor="{StaticResource SurfaceAlt}"
                            AutoSize="TextChanges"
                            MinimumHeightRequest="84"
                            MaxLength="200" />

                    <Label Text="牌阵" TextColor="{StaticResource TextSecondary}" FontSize="13" Margin="0,4,0,0" />
                    <Picker x:Name="SpreadPicker"
                            Title="选择牌阵"
                            TextColor="{StaticResource TextPrimary}"
                            BackgroundColor="{StaticResource SurfaceAlt}"
                            SelectedIndexChanged="OnSpreadChanged" />

                    <HorizontalStackLayout Spacing="8">
                        <Border Padding="6,2"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                Stroke="{StaticResource GoldDim}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <Label x:Name="SpreadDifficultyLabel"
                                   FontSize="11"
                                   TextColor="{StaticResource Gold}" />
                        </Border>
                        <Label x:Name="SpreadDescriptionLabel"
                               TextColor="{StaticResource Muted}"
                               FontSize="12"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap"
                               HorizontalOptions="Fill" />
                    </HorizontalStackLayout>

                    <Button x:Name="AdvancedToggleButton"
                            Text="▸ 高级选项"
                            Clicked="OnAdvancedToggleClicked"
                            FontSize="12"
                            Padding="0,4"
                            HorizontalOptions="Start"
                            TextColor="{StaticResource TextSecondary}"
                            BackgroundColor="Transparent"
                            BorderWidth="0" />
                    <VerticalStackLayout x:Name="AdvancedPanel"
                                         IsVisible="False"
                                         Spacing="4"
                                         Padding="0,0,0,0">
                        <Label Text="随机种子（留空则每次不同）"
                               TextColor="{StaticResource Muted}" FontSize="12" />
                        <Entry x:Name="SeedEntry"
                               Keyboard="Numeric"
                               Placeholder="如 42"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="{StaticResource SurfaceAlt}" />
                    </VerticalStackLayout>

                    <Button x:Name="DrawButton"
                            Text="✦  开始抽牌"
                            Clicked="OnDrawClicked"
                            TextColor="#1A1208"
                            FontAttributes="Bold"
                            FontSize="16"
                            BackgroundColor="{StaticResource Gold}"
                            Padding="18,13"
                            CornerRadius="12"
                            HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="EmptyStatePanel"
                    Stroke="{StaticResource StrokeSoft}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource SurfaceRaised}"
                    Padding="24,32"
                    StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="✦"
                           FontSize="36"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource GoldDim}" />
                    <Label Text="输入问题并选择牌阵，然后抽牌"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource Muted}"
                           FontSize="14" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ReadingPanel"
                    IsVisible="False"
                    Stroke="{StaticResource StrokeSoft}"
                    StrokeThickness="1"
                    Background="{StaticResource CardGradient}"
                    Padding="16"
                    StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="14">
                    <Label x:Name="ReadingTitleLabel"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PurpleLight}" />
                    <Label x:Name="ReadingMetaLabel"
                           FontSize="12"
                           TextColor="{StaticResource TextSecondary}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Button x:Name="SpreadToggleButton"
                                Grid.Column="0"
                                Text="▾ 牌阵布局"
                                Clicked="OnSpreadToggleClicked"
                                FontSize="13"
                                Padding="0,4"
                                HorizontalOptions="Start"
                                TextColor="{StaticResource Gold}"
                                BackgroundColor="Transparent"
                                BorderWidth="0" />
                        <Button Grid.Column="1"
                                Text="复制牌阵"
                                FontSize="11"
                                Padding="8,4"
                                CornerRadius="10"
                                Clicked="OnCopySpreadClicked"
                                TextColor="{StaticResource Gold}"
                                BackgroundColor="Transparent"
                                BorderColor="{StaticResource GoldDim}"
                                BorderWidth="1" />
                    </Grid>

                    <VerticalStackLayout x:Name="SpreadBoardPanel" IsVisible="True" Spacing="0">
                        <Grid x:Name="SpreadBoardHost"
                              ColumnDefinitions="*"
                              RowDefinitions="Auto"
                              ColumnSpacing="8"
                              RowSpacing="8" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="AI 解读"
                                x:Name="InterpretButton"
                                Clicked="OnInterpretClicked"
                                IsEnabled="False"
                                TextColor="#1A1208"
                                FontAttributes="Bold"
                                BackgroundColor="{StaticResource Gold}"
                                CornerRadius="12"
                                Padding="14,12" />
                        <Button Grid.Column="1"
                                Text="重新抽牌"
                                Clicked="OnRedrawClicked"
                                TextColor="{StaticResource Gold}"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                BorderColor="{StaticResource GoldDim}"
                                BorderWidth="1"
                                CornerRadius="12"
                                Padding="14,12" />
                    </Grid>

                    <ActivityIndicator x:Name="LoadingIndicator"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="{StaticResource Gold}" />

                    <Border x:Name="InterpretationPanel"
                            IsVisible="False"
                            Padding="14"
                            BackgroundColor="{StaticResource SurfaceAlt}"
                            Stroke="{StaticResource PurpleLight}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="解读"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource PurpleLight}" />
                                <Button Grid.Column="1"
                                        Text="复制"
                                        FontSize="12"
                                        Padding="10,4"
                                        CornerRadius="12"
                                        Clicked="OnCopyInterpretationClicked"
                                        TextColor="{StaticResource Gold}"
                                        BackgroundColor="Transparent"
                                        BorderColor="{StaticResource GoldDim}"
                                        BorderWidth="1" />
                            </Grid>
                            <Label x:Name="InterpretationStatusLabel"
                                   FontSize="12"
                                   TextColor="{StaticResource Muted}" />
                            <VerticalStackLayout x:Name="InterpretationBoardHost"
                                                 Spacing="12" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border x:Name="HistoryPanel"
                    IsVisible="False"
                    Stroke="{StaticResource StrokeSoft}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource SurfaceRaised}"
                    Padding="16"
                    StrokeShape="RoundRectangle 12">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="最近抽牌（点击查看详情）"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gold}" />
                        <Button Grid.Column="1"
                                Text="清空"
                                FontSize="11"
                                Padding="8,2"
                                CornerRadius="8"
                                Clicked="OnClearHistoryClicked"
                                TextColor="{StaticResource Muted}"
                                BackgroundColor="Transparent"
                                BorderColor="{StaticResource GoldDim}"
                                BorderWidth="1" />
                    </Grid>
                    <CollectionView x:Name="HistoryCollection"
                                    SelectionMode="Single"
                                    SelectionChanged="OnHistorySelected"
                                    HeightRequest="120">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="services:HistoryEntry">
                                <Border Padding="10,8"
                                        Margin="0,0,0,8"
                                        BackgroundColor="{StaticResource SurfaceAlt}"
                                        Stroke="{StaticResource StrokeSoft}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8">
                                    <Label Text="{Binding DisplayLine}"
                                           FontSize="12"
                                           TextColor="{StaticResource TextSecondary}"
                                           LineBreakMode="TailTruncation" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
