<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.Tarot.App.Pages.PersonalityQuizPage"
             Title="人格测评"
             Shell.NavBarIsVisible="True"
             Shell.TabBarIsVisible="False"
             Background="{StaticResource PageGradient}">

    <ScrollView x:Name="MainScroll">
        <VerticalStackLayout Padding="20,20" Spacing="16">
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="True"
                               IsVisible="True"
                               Color="{StaticResource Gold}" />

            <VerticalStackLayout x:Name="QuizHost" IsVisible="False" Spacing="16">
                <Label x:Name="TitleLabel"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Gold}" />
                <Label x:Name="SubtitleLabel"
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}"
                       LineBreakMode="WordWrap" />
                <Label x:Name="DisclaimerLabel"
                       FontSize="11"
                       TextColor="{StaticResource Muted}"
                       LineBreakMode="WordWrap" />
                <Label x:Name="ProgressLabel"
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}" />

                <Border Stroke="{StaticResource GoldDim}" StrokeThickness="1"
                        BackgroundColor="{StaticResource Surface}" Padding="16"
                        StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="QuestionLabel"
                               FontSize="16"
                               TextColor="{StaticResource TextPrimary}"
                               LineBreakMode="WordWrap" />
                        <VerticalStackLayout x:Name="OptionsHost" Spacing="8" />
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="ResultPanel"
                        IsVisible="False"
                        Stroke="{StaticResource Purple}"
                        StrokeThickness="1"
                        Background="{StaticResource CardGradient}"
                        Padding="16"
                        StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="ResultCodeLabel"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gold}" />
                        <Label x:Name="ResultTitleLabel"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PurpleLight}" />
                        <Label x:Name="ResultSummaryLabel"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"
                               LineBreakMode="WordWrap" />
                        <VerticalStackLayout x:Name="DimensionBarsHost" Spacing="10" />
                        <VerticalStackLayout x:Name="ResultSectionsHost" Spacing="4" />
                        <Button Text="保存长图"
                                Clicked="OnSaveImageClicked"
                                TextColor="{StaticResource Gold}"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                BorderColor="{StaticResource GoldDim}"
                                BorderWidth="1"
                                CornerRadius="24"
                                Padding="14,12" />
                        <Button Text="重新测试"
                                Clicked="OnRestartClicked"
                                TextColor="#1A1208"
                                FontAttributes="Bold"
                                BackgroundColor="{StaticResource Gold}"
                                CornerRadius="24"
                                Padding="14,12" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
