<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.Tarot.App.Pages.SpiritCardPage"
             Title="牌灵对应"
             Shell.NavBarIsVisible="True"
             Shell.TabBarIsVisible="False"
             Background="{StaticResource PageGradient}">

    <ScrollView x:Name="MainScroll">
        <VerticalStackLayout Padding="22,26,22,34"
                             Spacing="18"
                             MaximumWidthRequest="820"
                             HorizontalOptions="Center">
            <VerticalStackLayout Spacing="5">
                <Label Text="发现你的牌灵" Style="{StaticResource PageTitle}" />
                <Label Text="按生日映射一张属于你的塔罗原型牌。"
                       Style="{StaticResource PageKicker}" />
            </VerticalStackLayout>

            <Border Style="{StaticResource TarotCardPanel}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="生日" Style="{StaticResource Caption}" />
                    <DatePicker x:Name="BirthdayPicker"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="{StaticResource SurfaceAlt}" />
                    <Button Text="发现牌灵"
                            Clicked="OnDiscoverClicked"
                            Style="{StaticResource GoldButton}" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ResultPanel"
                    IsVisible="False"
                    Style="{StaticResource TarotCardPanel}">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="CardTitleLabel"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PurpleLight}" />
                    <Image x:Name="CardImage"
                           Aspect="AspectFit"
                           HeightRequest="260"
                           HorizontalOptions="Center" />
                    <Label x:Name="CardMeaningLabel"
                           FontSize="14"
                           TextColor="{StaticResource TextPrimary}"
                           LineBreakMode="WordWrap" />
                    <Button Text="保存长图"
                            Clicked="OnSaveImageClicked"
                            Style="{StaticResource OutlineButton}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
