<Window x:Class="IChing.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IChing Desktop" Height="760" Width="1120" MinHeight="680" MinWidth="980">
    <Grid Background="#F3F5F6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#162129" Padding="16">
            <StackPanel>
                <TextBlock Text="IChing" Foreground="White" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="Desktop Reading" Foreground="#B8C4C8" Margin="0,4,0,22" />

                <Button x:Name="BaziButton" Content="BaZi" Click="SwitchDomain" Tag="bazi" Margin="0,0,0,8" Height="40" />
                <Button x:Name="LiuyaoButton" Content="Liuyao" Click="SwitchDomain" Tag="liuyao" Margin="0,0,0,8" Height="40" />
                <Button x:Name="TarotButton" Content="Tarot" Click="SwitchDomain" Tag="tarot" Margin="0,0,0,8" Height="40" />
                <Button x:Name="SettingsButton" Content="Settings" Click="SwitchDomain" Tag="settings" Height="40" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,0,14">
                <Button Content="Calculate" Width="110" Height="36" DockPanel.Dock="Right" Click="Calculate_Click" />
                <Button Content="Interpret" Width="110" Height="36" DockPanel.Dock="Right" Margin="0,0,10,0" Click="Interpret_Click" />
                <TextBlock x:Name="TitleText" Text="BaZi" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" />
            </DockPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel x:Name="BaziPanel">
                            <TextBlock Text="Birth" FontWeight="Bold" Margin="0,0,0,8" />
                            <UniformGrid Columns="2">
                                <TextBox x:Name="BaziYear" Text="1990" Margin="0,0,8,8" />
                                <TextBox x:Name="BaziMonth" Text="5" Margin="0,0,0,8" />
                                <TextBox x:Name="BaziDay" Text="20" Margin="0,0,8,8" />
                                <TextBox x:Name="BaziHour" Text="10" Margin="0,0,0,8" />
                                <TextBox x:Name="BaziMinute" Text="0" Margin="0,0,8,8" />
                                <ComboBox x:Name="BaziGender" SelectedIndex="1" Margin="0,0,0,8">
                                    <ComboBoxItem Content="Unknown" Tag="" />
                                    <ComboBoxItem Content="Male / 1" Tag="1" />
                                    <ComboBoxItem Content="Female / 0" Tag="0" />
                                </ComboBox>
                            </UniformGrid>
                            <TextBox x:Name="BaziCity" ToolTip="City" Margin="0,0,0,8" />
                            <TextBox x:Name="BaziLongitude" ToolTip="Longitude" Margin="0,0,0,8" />
                            <TextBox x:Name="BaziFocus" Text="career" ToolTip="Focus" Margin="0,0,0,8" />
                        </StackPanel>

                        <StackPanel x:Name="LiuyaoPanel" Visibility="Collapsed">
                            <TextBlock Text="Casting" FontWeight="Bold" Margin="0,0,0,8" />
                            <ComboBox x:Name="LiuyaoMethod" SelectedIndex="0" Margin="0,0,0,8">
                                <ComboBoxItem Content="Coin" Tag="coin" />
                                <ComboBoxItem Content="Time" Tag="time" />
                            </ComboBox>
                            <TextBox x:Name="LiuyaoQuestion" Text="How will this develop?" Margin="0,0,0,8" />
                            <TextBox x:Name="LiuyaoFocus" Text="general" Margin="0,0,0,8" />
                            <TextBox x:Name="LiuyaoSeed" Text="42" ToolTip="Optional seed" Margin="0,0,0,8" />
                        </StackPanel>

                        <StackPanel x:Name="TarotPanel" Visibility="Collapsed">
                            <TextBlock Text="Spread" FontWeight="Bold" Margin="0,0,0,8" />
                            <ComboBox x:Name="TarotSpread" DisplayMemberPath="TitleZh" SelectedValuePath="Id" Margin="0,0,0,8" />
                            <TextBox x:Name="TarotQuestion" Text="career" Margin="0,0,0,8" />
                            <TextBox x:Name="TarotSeed" Text="42" ToolTip="Optional seed" Margin="0,0,0,8" />
                        </StackPanel>

                        <StackPanel x:Name="SettingsPanel" Visibility="Collapsed">
                            <TextBlock Text="OpenAI-compatible API" FontWeight="Bold" Margin="0,0,0,8" />
                            <TextBox x:Name="BaseUrlBox" Margin="0,0,0,8" />
                            <TextBox x:Name="ModelBox" Margin="0,0,0,8" />
                            <PasswordBox x:Name="ApiKeyBox" Margin="0,0,0,8" />
                            <Button Content="Save Settings" Height="36" Click="SaveSettings_Click" />
                            <TextBlock Text="Key is encrypted with the current Windows user when possible." TextWrapping="Wrap" Margin="0,10,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Column="1" Margin="18,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="2*" />
                    </Grid.RowDefinitions>
                    <TextBox x:Name="ResultBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" />
                    <TextBox x:Name="InterpretBox" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
