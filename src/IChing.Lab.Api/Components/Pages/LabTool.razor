@page "/lab-tool"
@rendermode InteractiveServer
@using System.Text.Encodings.Web
@using System.Text.Json
@using IChing.Lab.Core.Bazi
@using IChing.Lab.Core.Calendar
@using IChing.Lab.Core.Liuyao
@using IChing.Lab.Core.Tarot
@using IChing.Lab.Inference
@inject ChartInterpretationService Interpretation

<main class="shell">
    <header>
        <h1>IChing Lab Tool</h1>
        <p>One page for backend smoke testing: bazi, hepan, liuyao, tarot, huangli, and model status.</p>
    </header>

    <section class="grid">
        <form class="panel" @onsubmit:preventDefault>
            <h2>Bazi</h2>
            <div class="fields">
                <label>Year <input type="number" @bind="bazi.Year" /></label>
                <label>Month <input type="number" min="1" max="12" @bind="bazi.Month" /></label>
                <label>Day <input type="number" min="1" max="31" @bind="bazi.Day" /></label>
                <label>Hour <input type="number" min="0" max="23" @bind="bazi.Hour" /></label>
                <label>Minute <input type="number" min="0" max="59" @bind="bazi.Minute" /></label>
                <label>Gender <select @bind="bazi.Gender"><option value="">-</option><option value="1">1</option><option value="0">0</option></select></label>
                <label>City <input @bind="bazi.City" /></label>
                <label>Longitude <input type="number" step="0.01" @bind="bazi.Longitude" /></label>
                <label>Flow year <input type="number" @bind="bazi.FlowYear" /></label>
                <label>Flow month <input type="number" min="1" max="12" @bind="bazi.FlowMonth" /></label>
                <label>Calendar month <input type="number" min="1" max="12" @bind="bazi.FlowCalendarMonth" /></label>
                <label>Flow day <input type="number" min="1" max="31" @bind="bazi.FlowDay" /></label>
                <label class="wide">Focus <input @bind="bazi.Focus" /></label>
            </div>
            <div class="actions">
                <button type="button" @onclick="RunBazi">Chart</button>
                <button type="button" @onclick="RunBaziRead">Read</button>
                <button type="button" @onclick="RunHePan">HePan</button>
            </div>
        </form>

        <form class="panel" @onsubmit:preventDefault>
            <h2>Other Tools</h2>
            <div class="fields">
                <label>Question <input @bind="question" /></label>
                <label>Seed <input type="number" @bind="seed" /></label>
                <label>Spread <select @bind="spreadId">@foreach (var spread in SpreadCatalog.List()) { <option value="@spread.Id">@spread.Id</option> }</select></label>
                <label>Liuyao method <select @bind="liuyaoMethod"><option value="coin">coin</option><option value="time">time</option></select></label>
                <label>At <input type="datetime-local" @bind="at" /></label>
                <label>Huangli date <input type="date" @bind="huangliDate" /></label>
            </div>
            <div class="actions">
                <button type="button" @onclick="RunLiuyao">Liuyao</button>
                <button type="button" @onclick="RunTarot">Tarot</button>
                <button type="button" @onclick="RunHuangLi">HuangLi</button>
                <button type="button" @onclick="RunModelStatus">Model</button>
            </div>
        </form>
    </section>

    <section class="result">
        <div class="resultBar">
            <strong>@resultTitle</strong>
            <button type="button" @onclick="Clear">Clear</button>
        </div>
        <pre>@resultJson</pre>
    </section>
</main>

@code {
    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        WriteIndented = true,
        Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping
    };

    private readonly BaziForm bazi = new();
    private string question = "career";
    private int? seed = 42;
    private string spreadId = "past-present-future";
    private string liuyaoMethod = "coin";
    private DateTime at = DateTime.Now;
    private DateTime huangliDate = DateTime.Today;
    private string resultTitle = "Result";
    private string resultJson = "{}";

    private void RunBazi() => Show("Bazi", BaziEngine.Calculate(bazi.ToInput()));

    private void RunBaziRead()
    {
        var chart = BaziEngine.Calculate(bazi.ToInput());
        var result = Interpretation.Interpret(chart, bazi.Focus, 512);
        Show("Bazi Read", new { chart, interpretation = result });
    }

    private void RunHePan()
    {
        var other = new BaziInput(1992, 8, 15, 14, Gender: 0);
        Show("HePan", HePanService.Compare(BaziEngine.Calculate(bazi.ToInput()), BaziEngine.Calculate(other)));
    }

    private void RunLiuyao()
    {
        var time = new DateTimeOffset(at);
        Show("Liuyao", liuyaoMethod == "time" ? LiuyaoNajiaService.Time(time) : LiuyaoNajiaService.Coin(time, seed));
    }

    private void RunTarot() => Show("Tarot", TarotEngine.Draw(spreadId, question, seed));

    private void RunHuangLi() => Show("HuangLi", HuangLiService.GetDay(huangliDate.Year, huangliDate.Month, huangliDate.Day));

    private void RunModelStatus() => Show("Model Status", new { loaded = Interpretation.IsModelLoaded });

    private void Clear()
    {
        resultTitle = "Result";
        resultJson = "{}";
    }

    private void Show(string title, object value)
    {
        resultTitle = title;
        try
        {
            resultJson = JsonSerializer.Serialize(value, JsonOptions);
        }
        catch (Exception ex)
        {
            resultTitle = "Error";
            resultJson = JsonSerializer.Serialize(new { error = ex.Message }, JsonOptions);
        }
    }

    private sealed class BaziForm
    {
        public int Year { get; set; } = 1990;
        public int Month { get; set; } = 5;
        public int Day { get; set; } = 20;
        public int Hour { get; set; } = 10;
        public int Minute { get; set; }
        public int? Gender { get; set; } = 1;
        public string? City { get; set; }
        public double? Longitude { get; set; }
        public int? FlowYear { get; set; } = 2026;
        public int? FlowMonth { get; set; }
        public int? FlowCalendarMonth { get; set; }
        public int? FlowDay { get; set; }
        public string? Focus { get; set; } = "career";

        public BaziInput ToInput() => new(
            Year, Month, Day, Hour, Minute,
            Gender: Gender,
            City: string.IsNullOrWhiteSpace(City) ? null : City,
            Longitude: Longitude,
            FlowYear: FlowYear,
            FlowMonth: FlowMonth,
            FlowCalendarMonth: FlowCalendarMonth,
            FlowDay: FlowDay);
    }
}

<style>
    .shell {
        max-width: 1280px;
        margin: 0 auto;
        padding: 24px;
    }

    header {
        margin-bottom: 18px;
    }

    h1, h2, p {
        margin: 0;
    }

    h1 {
        font-size: 28px;
    }

    h2 {
        font-size: 16px;
        margin-bottom: 12px;
    }

    p {
        margin-top: 6px;
        color: #5b6770;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
        gap: 16px;
        align-items: start;
    }

    .panel, .result {
        border: 1px solid #d9dee3;
        border-radius: 8px;
        background: #fff;
        padding: 16px;
    }

    .fields {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 10px;
    }

    label {
        display: grid;
        gap: 4px;
        color: #43505a;
        font-size: 13px;
    }

    .wide {
        grid-column: 1 / -1;
    }

    input, select {
        min-width: 0;
        border: 1px solid #c9d0d6;
        border-radius: 6px;
        padding: 8px 9px;
        background: #fff;
        color: #172026;
    }

    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 14px;
    }

    button {
        border: 1px solid #25313b;
        border-radius: 6px;
        padding: 8px 12px;
        background: #25313b;
        color: #fff;
    }

    .result {
        margin-top: 16px;
    }

    .resultBar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }

    pre {
        min-height: 360px;
        overflow: auto;
        margin: 0;
        border-radius: 6px;
        background: #111820;
        color: #dbe7ef;
        padding: 14px;
        font-size: 13px;
        line-height: 1.5;
    }
</style>
