<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.Tarot.App.Pages.FollowUpChatPage"
             Title="追问"
             Background="{StaticResource PageGradient}">
    <Grid RowDefinitions="Auto,*,Auto"
          Padding="16"
          RowSpacing="10">
        <Label x:Name="RoundLabel"
               Text="第 0/3 轮"
               FontSize="13"
               TextColor="{StaticResource Muted}"
               HorizontalOptions="Center" />
        <ScrollView x:Name="ChatScroll" Grid.Row="1">
            <VerticalStackLayout x:Name="ChatHost"
                                 Spacing="10"
                                 MaximumWidthRequest="860"
                                 HorizontalOptions="Center" />
        </ScrollView>
        <Border Grid.Row="2"
                Padding="10"
                MaximumWidthRequest="860"
                HorizontalOptions="Center"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource StrokeSoft}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8">
            <VerticalStackLayout Spacing="8">
                <Label x:Name="LimitHintLabel"
                       IsVisible="False"
                       Text="本局追问已达 3 轮上限。若仍有困惑，可新开一局抽牌后再追问。"
                       FontSize="12"
                       TextColor="{StaticResource Muted}"
                       LineBreakMode="WordWrap" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Entry x:Name="QuestionEntry"
                           Placeholder="继续追问，最多三轮"
                           TextColor="{StaticResource TextPrimary}"
                           BackgroundColor="{StaticResource SurfaceAlt}" />
                    <Button Grid.Column="1"
                            x:Name="SendButton"
                            Text="发送"
                            Clicked="OnSendClicked"
                            Style="{StaticResource GoldButton}" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
