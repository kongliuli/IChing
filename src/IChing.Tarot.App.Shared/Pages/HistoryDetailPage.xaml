<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.Tarot.App.Pages.HistoryDetailPage"
             Title="历史详情"
             Shell.NavBarIsVisible="True"
             Shell.TabBarIsVisible="False"
             Background="{StaticResource PageGradient}">

    <ScrollView>
        <VerticalStackLayout Padding="22,24,22,34"
                             Spacing="14"
                             MaximumWidthRequest="980"
                             HorizontalOptions="Center">
            <Border Style="{StaticResource TarotCardPanel}">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="TitleLabel"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PurpleLight}" />
                    <Label x:Name="MetaLabel"
                           FontSize="12"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </Border>

            <Grid x:Name="SpreadBoardHost"
                  ColumnDefinitions="*"
                  RowDefinitions="Auto"
                  ColumnSpacing="8"
                  RowSpacing="8" />

            <Border x:Name="InterpretationPanel"
                    IsVisible="False"
                    Style="{StaticResource TarotCardPanel}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="解读正文"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gold}" />
                    <Label x:Name="InterpretationLabel"
                           FontSize="13"
                           TextColor="{StaticResource TextPrimary}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
