<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.App.Pages.SettingsPage"
             Title="设置">
    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,32"
                             Spacing="14"
                             MaximumWidthRequest="760"
                             HorizontalOptions="Fill">
            <VerticalStackLayout Spacing="2">
                <Label Text="设置"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />
                <BoxView HeightRequest="2"
                         WidthRequest="40"
                         HorizontalOptions="Start"
                         Color="{StaticResource Gold}" />
            </VerticalStackLayout>

            <Border Stroke="{StaticResource StrokeSoft}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}"
                    Padding="14"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="12">
                    <Label Text="AI 解读"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gold}" />

                    <Label Text="服务商" FontSize="12" TextColor="{StaticResource Muted}" />
                    <Picker x:Name="ProviderPicker" SelectedIndexChanged="OnProviderChanged">
                        <Picker.Items>
                            <x:String>DeepSeek</x:String>
                            <x:String>OpenAI</x:String>
                            <x:String>自定义</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label Text="API Base URL" FontSize="12" TextColor="{StaticResource Muted}" />
                    <Entry x:Name="BaseUrlEntry" />

                    <Label Text="模型" FontSize="12" TextColor="{StaticResource Muted}" />
                    <Entry x:Name="ModelEntry" />

                    <Label Text="API Key" FontSize="12" TextColor="{StaticResource Muted}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry x:Name="ApiKeyEntry"
                               IsPassword="True"
                               Placeholder="sk-..." />
                        <Button x:Name="ToggleKeyButton"
                                Grid.Column="1"
                                Text="显示"
                                FontSize="12"
                                Clicked="OnToggleKeyClicked"
                                TextColor="{StaticResource Gold}"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                BorderColor="{StaticResource StrokeSoft}"
                                BorderWidth="1" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="温度" FontSize="12" TextColor="{StaticResource Muted}" />
                            <Entry x:Name="TemperatureEntry" Text="0.6" Placeholder="0-1" Keyboard="Numeric" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="最大 tokens" FontSize="12" TextColor="{StaticResource Muted}" />
                            <Entry x:Name="MaxTokensEntry" Text="700" Placeholder="700" Keyboard="Numeric" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="保存"
                                Clicked="OnSaveClicked"
                                TextColor="#171006"
                                BackgroundColor="{StaticResource Gold}" />
                        <Button x:Name="TestButton"
                                Grid.Column="1"
                                Text="测试连接"
                                Clicked="OnTestClicked"
                                TextColor="{StaticResource Gold}"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                BorderColor="{StaticResource StrokeSoft}"
                                BorderWidth="1" />
                    </Grid>

                    <ActivityIndicator x:Name="TestIndicator"
                                       IsVisible="False"
                                       IsRunning="False"
                                       Color="{StaticResource Gold}" />
                    <Label x:Name="StatusLabel"
                           FontSize="13"
                           TextColor="{StaticResource Muted}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
