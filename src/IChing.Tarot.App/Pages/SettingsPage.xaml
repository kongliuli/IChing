<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.Tarot.App.Pages.SettingsPage"
             Title="设置"
             Background="{StaticResource PageGradient}">

    <ScrollView>
        <VerticalStackLayout Padding="22,24,22,34"
                             Spacing="16"
                             MaximumWidthRequest="920"
                             HorizontalOptions="Center">
            <Label Text="解读 API 设置"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Gold}" />
            <Label Text="API Key 仅保存在本机。抽牌与 Deckaura 牌义在本地运行，解读时才联网。"
                   TextColor="{StaticResource TextSecondary}"
                   LineBreakMode="WordWrap" />

            <Border Stroke="{StaticResource StrokeSoft}" StrokeThickness="1"
                    Background="{StaticResource CardGradient}" Padding="18"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="12">
                    <Label Text="服务商预设" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <Picker x:Name="ProviderPicker"
                            Title="选择服务商"
                            SelectedIndexChanged="OnProviderChanged"
                            TextColor="{StaticResource TextPrimary}"
                            BackgroundColor="{StaticResource SurfaceAlt}">
                        <Picker.Items>
                            <x:String>DeepSeek</x:String>
                            <x:String>OpenAI</x:String>
                            <x:String>自定义</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label Text="API Base URL" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <Entry x:Name="BaseUrlEntry"
                           TextColor="{StaticResource TextPrimary}"
                           BackgroundColor="{StaticResource SurfaceAlt}" />

                    <Label Text="模型名称" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <Entry x:Name="ModelEntry"
                           TextColor="{StaticResource TextPrimary}"
                           BackgroundColor="{StaticResource SurfaceAlt}" />

                    <Label Text="API Key" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry x:Name="ApiKeyEntry"
                               Grid.Column="0"
                               IsPassword="True"
                               Placeholder="sk-..."
                               PlaceholderColor="{StaticResource Muted}"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="{StaticResource SurfaceAlt}" />
                        <Button Grid.Column="1"
                                x:Name="ToggleKeyButton"
                                Text="显示"
                                FontSize="12"
                                Padding="12,8"
                                CornerRadius="8"
                                Clicked="OnToggleKeyClicked"
                                TextColor="{StaticResource Gold}"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                BorderColor="{StaticResource GoldDim}"
                                BorderWidth="1" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="保存设置"
                                Clicked="OnSaveClicked"
                                TextColor="#1A1208"
                                FontAttributes="Bold"
                                BackgroundColor="{StaticResource Gold}"
                                CornerRadius="8"
                                Padding="14,12" />
                        <Button Grid.Column="1"
                                Text="测试连接"
                                Clicked="OnTestClicked"
                                x:Name="TestButton"
                                TextColor="{StaticResource Gold}"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                BorderColor="{StaticResource StrokeSoft}"
                                BorderWidth="1"
                                CornerRadius="8"
                                Padding="14,12" />
                    </Grid>

                    <ActivityIndicator x:Name="TestIndicator"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="{StaticResource Gold}" />

                    <Label x:Name="StatusLabel"
                           FontSize="13"
                           TextColor="{StaticResource Muted}" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="{StaticResource GoldDim}" StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}" Padding="16"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="14">
                    <Label Text="牌面图缓存"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gold}" />
                    <Label Text="牌面图按需从 CDN 下载并缓存在本机，可显著减小安装包体积。首次抽牌需联网。"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           LineBreakMode="WordWrap" />

                    <Label x:Name="CacheStatusLabel"
                           FontSize="13"
                           TextColor="{StaticResource Muted}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                x:Name="PreloadButton"
                                Text="预下载全部"
                                Clicked="OnPreloadClicked"
                                TextColor="#1A1208"
                                FontAttributes="Bold"
                                BackgroundColor="{StaticResource Gold}"
                                CornerRadius="8"
                                Padding="14,12" />
                        <Button Grid.Column="1"
                                x:Name="ClearCacheButton"
                                Text="清除缓存"
                                Clicked="OnClearCacheClicked"
                                TextColor="{StaticResource Gold}"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                BorderColor="{StaticResource GoldDim}"
                                BorderWidth="1"
                                CornerRadius="8"
                                Padding="14,12" />
                    </Grid>

                    <ActivityIndicator x:Name="CacheIndicator"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="{StaticResource Gold}" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="LabApiPanel"
                    IsVisible="False"
                    Stroke="{StaticResource StrokeSoft}" StrokeThickness="1"
                    BackgroundColor="{StaticResource SurfaceRaised}" Padding="18"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Lab API（可选）"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gold}" />
                    <Label Text="启用后优先调用 IChing.Lab.Api 的 /lab/tarot/read，使用 ONNX 或降级链解读。"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           LineBreakMode="WordWrap" />

                    <Switch x:Name="UseLabSwitch"
                            Toggled="OnUseLabToggled"
                            OnColor="{StaticResource Gold}" />

                    <Label Text="Lab API 地址" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <Entry x:Name="LabApiUrlEntry"
                           Placeholder="http://localhost:5000"
                           TextColor="{StaticResource TextPrimary}"
                           BackgroundColor="{StaticResource SurfaceAlt}" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="VersionLabel"
                   FontSize="12"
                   TextColor="{StaticResource Muted}"
                   HorizontalTextAlignment="Center"
                   Margin="0,8,0,0" />

            <Border x:Name="AndroidToolsPanel"
                    IsVisible="False"
                    Stroke="{StaticResource GoldDim}" StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}" Padding="16"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Android 工具"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gold}" />
                    <Label Text="若系统安装界面只有「完成」，更新后会收到「点击打开」通知；首次安装后打开 App 也会提示进入探索。"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           LineBreakMode="WordWrap" />
                    <Button x:Name="InstallApkButton"
                            Text="从文件安装 APK"
                            Clicked="OnInstallApkClicked"
                            TextColor="{StaticResource Gold}"
                            BackgroundColor="{StaticResource SurfaceAlt}"
                            BorderColor="{StaticResource GoldDim}"
                            BorderWidth="1"
                            CornerRadius="8"
                            Padding="14,12" />
                    <Label Text="探索模块配置"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PurpleLight}"
                           FontSize="15" />
                    <Label x:Name="ExploreConfigPathLabel"
                           FontSize="11"
                           TextColor="{StaticResource Muted}"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

