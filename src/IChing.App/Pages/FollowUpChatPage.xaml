<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.App.Pages.FollowUpChatPage"
             Title="追问">
    <Grid RowDefinitions="*,Auto" Padding="14" RowSpacing="10" BackgroundColor="{StaticResource Background}">
        <ScrollView x:Name="ChatScroll">
            <VerticalStackLayout x:Name="ChatHost" Spacing="10" />
        </ScrollView>
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry x:Name="QuestionEntry" Placeholder="继续追问，最多三轮" />
            <Button Grid.Column="1"
                    x:Name="SendButton"
                    Text="发送"
                    Clicked="OnSendClicked"
                    TextColor="{StaticResource White}"
                    BackgroundColor="{StaticResource Jade}" />
        </Grid>
    </Grid>
</ContentPage>
