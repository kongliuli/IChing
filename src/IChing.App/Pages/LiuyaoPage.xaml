<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.App.Pages.LiuyaoPage"
             Shell.NavBarIsVisible="False"
             Title="六爻">
    <ScrollView>
        <VerticalStackLayout Padding="22,24,22,36"
                             Spacing="18"
                             MaximumWidthRequest="1120"
                             HorizontalOptions="Center">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <VerticalStackLayout Spacing="5">
                    <Label Text="六爻起卦" Style="{StaticResource PageTitle}" />
                    <Label Text="铜钱起卦 · 纳甲六亲 · 世应用神"
                           Style="{StaticResource PageKicker}" />
                    <BoxView HeightRequest="2"
                             WidthRequest="56"
                             HorizontalOptions="Start"
                             Color="{StaticResource Cinnabar}" />
                </VerticalStackLayout>
                <Border Grid.Column="1"
                        WidthRequest="58"
                        HeightRequest="58"
                        Stroke="{StaticResource Cinnabar}"
                        StrokeThickness="2"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 8"
                        HorizontalOptions="End">
                    <Label Text="卦"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Cinnabar}"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Border>
            </Grid>

            <Grid x:Name="ResponsiveGrid"
                  ColumnDefinitions="1.02*,0.98*"
                  RowDefinitions="Auto"
                  ColumnSpacing="16"
                  RowSpacing="16">
                <Border x:Name="InputPanel"
                        Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="起卦信息" Style="{StaticResource SectionTitle}" />
                        <Editor x:Name="QuestionEntry"
                                Placeholder="请输入所问之事"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="96"
                                MaxLength="200" />
                        <Entry x:Name="FocusEntry" Text="事业" Placeholder="关注点，如事业、关系、财运" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Picker x:Name="MethodPicker" Title="起卦方式">
                                <Picker.Items>
                                    <x:String>铜钱卦</x:String>
                                    <x:String>时间卦</x:String>
                                </Picker.Items>
                            </Picker>
                            <Entry x:Name="SeedEntry" Grid.Column="1" Placeholder="随机种子，可空" Keyboard="Numeric" />
                        </Grid>
                        <Button Text="起卦"
                                Clicked="OnCastClicked"
                                Style="{StaticResource PrimaryButton}" />
                        <Label x:Name="ErrorLabel"
                               IsVisible="False"
                               FontSize="12"
                               TextColor="{StaticResource Danger}" />
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="PlaceholderPanel"
                        Grid.Column="1"
                        Style="{StaticResource RaisedCard}">
                    <VerticalStackLayout Spacing="16">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="卦盘预览"
                                   FontSize="23"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Cinnabar}" />
                            <Label Text="起卦后展示本卦、变卦、六亲、六神、世应与动爻。"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                            <Label Text="上爻        ━━━━━        六神 · 六亲" TextColor="{StaticResource Muted}" />
                            <Label Grid.Row="1" Text="五爻        ━━  ━━        六神 · 六亲" TextColor="{StaticResource Muted}" />
                            <Label Grid.Row="2" Text="四爻        ━━━━━        六神 · 六亲" TextColor="{StaticResource Muted}" />
                            <Label Grid.Row="3" Text="三爻        ━━  ━━        世 / 应" TextColor="{StaticResource Muted}" />
                            <Label Grid.Row="4" Text="二爻        ━━━━━        伏神 / 神煞" TextColor="{StaticResource Muted}" />
                            <Label Grid.Row="5" Text="初爻        ━━  ━━        动爻标记" TextColor="{StaticResource Muted}" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource StrokeSoft}" />

                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                            <Grid ColumnDefinitions="78,*" ColumnSpacing="10">
                                <Label Text="起卦" Style="{StaticResource Caption}" />
                                <Label Grid.Column="1" Text="铜钱卦或时间卦" TextColor="{StaticResource TextPrimary}" />
                            </Grid>
                            <Grid Grid.Row="1" ColumnDefinitions="78,*" ColumnSpacing="10">
                                <Label Text="判断" Style="{StaticResource Caption}" />
                                <Label Grid.Column="1" Text="先取用神，再看世应与动爻" TextColor="{StaticResource TextPrimary}" />
                            </Grid>
                            <Grid Grid.Row="2" ColumnDefinitions="78,*" ColumnSpacing="10">
                                <Label Text="输出" Style="{StaticResource Caption}" />
                                <Label Grid.Column="1" Text="本地卦盘后可追加 AI 解读" TextColor="{StaticResource TextPrimary}" />
                            </Grid>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="ResultPanel"
                        Grid.Column="1"
                        IsVisible="False"
                        Style="{StaticResource RaisedCard}">
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="3">
                            <Label x:Name="HexagramLabel"
                                   FontSize="23"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Cinnabar}" />
                            <Label x:Name="DigestLabel"
                                   FontSize="13"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>

                        <Border Padding="12"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                Stroke="{StaticResource StrokeSoft}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <CollectionView x:Name="LinesView"
                                            SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="58,*,Auto"
                                              ColumnSpacing="10"
                                              Padding="0,7">
                                            <Label Text="{Binding Position}"
                                                   Style="{StaticResource Caption}"
                                                   VerticalTextAlignment="Center" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Glyph}"
                                                   FontSize="22"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource Ink}"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center" />
                                            <VerticalStackLayout Grid.Column="2" Spacing="2" WidthRequest="132">
                                                <Label Text="{Binding Detail}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       HorizontalTextAlignment="End" />
                                                <Label Text="{Binding Marker}"
                                                       FontSize="11"
                                                       TextColor="{StaticResource Cinnabar}"
                                                       HorizontalTextAlignment="End" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Button x:Name="InterpretButton"
                                    Text="AI 解读"
                                    IsEnabled="False"
                                    Clicked="OnInterpretClicked"
                                    Style="{StaticResource JadeButton}" />
                            <ActivityIndicator x:Name="InterpretIndicator"
                                               Grid.Column="1"
                                               IsRunning="False"
                                               IsVisible="False"
                                               Color="{StaticResource Jade}" />
                        </Grid>

                        <Border x:Name="InterpretationPanel"
                                IsVisible="False"
                                Padding="14"
                                BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource StrokeSoft}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                    <Label x:Name="InterpretStatusLabel"
                                           Style="{StaticResource Caption}"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center" />
                                    <Button x:Name="ExportButton"
                                            Grid.Column="1"
                                            Text="导出图片"
                                            IsVisible="False"
                                            Clicked="OnExportClicked"
                                            Style="{StaticResource PrimaryButton}" />
                                    <Button x:Name="FollowUpButton"
                                            Grid.Column="2"
                                            Text="追问"
                                            IsVisible="False"
                                            Clicked="OnFollowUpClicked"
                                            Style="{StaticResource JadeButton}" />
                                </Grid>
                                <Label x:Name="InterpretationLabel"
                                       FontSize="13"
                                       TextColor="{StaticResource TextPrimary}" />
                                <WebView x:Name="ReadingWebView"
                                         IsVisible="False"
                                         HeightRequest="760" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
