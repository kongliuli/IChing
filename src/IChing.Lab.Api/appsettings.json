{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Accounts": {
    "Enabled": false,
    "BaseUrl": "http://localhost:5002",
    "RequireForTierGte": 1
  },
  "CommercialAi": {
    "Enabled": false,
    "BaseUrl": "https://api.deepseek.com/v1",
    "Model": "deepseek-chat",
    "ApiKeyEnvironmentVariable": "CommercialAi__ApiKey",
    "_comment": "商业版开启 Enabled=true，Key 用环境变量/User Secrets：CommercialAi__ApiKey 或 CommercialAi:ApiKey，绝不入仓。"
  },
  "Inference": {
    "ModelPath": "./models/qwen3.5-2b-genai",
    "MaxConcurrent": 1,
    "DefaultMaxTokens": 512
  },
  "Prompts": {
    "TemplateRoot": "./prompts"
  },
  "plugins": {
    "externalAssemblies": [
      { "name": "LLamaSharpEngine", "path": "plugins/LLamaSharpEngine.dll" },
      { "name": "OpenAiCompatibleEngine", "path": "plugins/OpenAiCompatibleEngine.dll" }
    ],
    "inferenceEngines": [
      { "id": "onnx-genai-qwen3.5-2b", "mode": "in-process", "default": true, "modelPath": "./models/qwen3.5-2b-genai" },
      { "id": "onnx-genai-qwen3.5-0.8b", "mode": "in-process", "modelPath": "./models/qwen3.5-0.8b-genai" },
      { "id": "llama-sharp-qwen3-4b", "mode": "in-process", "modelPath": "./models/qwen3-4b-q4_k_s.gguf", "gpuLayerCount": 0 },
      { "id": "ollama-local", "mode": "local-http", "baseUrl": "http://localhost:11434", "model": "qwen2.5:7b" },
      { "id": "llama-server-local", "mode": "local-http", "baseUrl": "http://localhost:8080", "model": "qwen3-4b-q4" },
      { "id": "openai-remote", "mode": "remote-api", "baseUrl": "https://api.openai.com/v1", "model": "gpt-4o-mini" },
      { "id": "azure-openai-remote", "mode": "remote-api", "baseUrl": "", "model": "gpt-4o" },
      { "id": "deepseek-remote", "mode": "remote-api", "baseUrl": "https://api.deepseek.com/v1", "model": "deepseek-chat", "apiKeyKey": "CommercialAi:ApiKey" }
    ],
    "fallbackChain": [ "deepseek-remote", "onnx-genai-qwen3.5-2b", "ollama-local", "openai-remote", "template-fallback" ],
    "chartEngines": [
      {
        "domain": "bazi",
        "default": "lunar-csharp-1.6.8",
        "fallback": [ "bazi-cnlunar-port", "bazi-openfate-bridge", "bazi-alvamind-bridge", "bazi-lunar-python-bridge", "bazi-mymcp-bridge" ]
      },
      {
        "domain": "liuyao",
        "default": "iching-sixlines-2.0.3",
        "fallback": [ "liuyao-yijingframework-annot", "liuyao-npm-bridge", "liuyao-ichingshifa-bridge", "liuyao-l2yao-bridge", "liuyao-zhouyilab-bridge" ]
      },
      {
        "domain": "tarot",
        "default": "iching-tarot-built-in",
        "fallback": [ "tarot-deckaura-data", "tarot-arcanite-bridge", "tarot-ttarot-bridge", "tarot-roxyapi-remote", "tarot-morax-mcp-bridge" ]
      },
      {
        "domain": "calendar",
        "default": "lunar-csharp-1.6.8",
        "fallback": [ "calendar-cnlunar-bridge", "calendar-lunar-calendar-bridge", "calendar-koyomi-remote", "calendar-lunar-python-bridge", "calendar-finddays-remote" ]
      }
    ]
  },
  "RuleEngine": {
    "MinWeight": 0,
    "Plugins": {
      "liuyao.yongshen.keyword": { "Enabled": true, "Weight": 100 },
      "liuyao.coin.probability": { "Enabled": true, "Weight": 70 },
      "liuyao.interpretation.traditional": { "Enabled": true, "Weight": 50 },
      "bazi.yongshen.current": { "Enabled": true, "Weight": 100 },
      "bazi.wuxing.balance": { "Enabled": true, "Weight": 90 },
      "tarot.stats.elements": { "Enabled": true, "Weight": 100 },
      "tarot.element.meaning": { "Enabled": true, "Weight": 90 }
    }
  }
}
