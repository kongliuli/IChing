<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.Tarot.App.Pages.DailyColorPage"
             Title="今日能量色"
             Shell.NavBarIsVisible="True"
             Shell.TabBarIsVisible="False"
             Background="{StaticResource PageGradient}">

    <ScrollView>
        <VerticalStackLayout Padding="22,26,22,34"
                             Spacing="18"
                             MaximumWidthRequest="760"
                             HorizontalOptions="Center">
            <VerticalStackLayout Spacing="5">
                <Label Text="今日能量色" Style="{StaticResource PageTitle}" />
                <Label Text="给今天一个明确的情绪锚点和行动提醒。"
                       Style="{StaticResource PageKicker}" />
            </VerticalStackLayout>

            <Border x:Name="ResultPanel" Style="{StaticResource TarotCardPanel}">
                <VerticalStackLayout Spacing="14">
                    <BoxView x:Name="ColorSwatch"
                             HeightRequest="132"
                             CornerRadius="8" />
                    <Label x:Name="ColorNameLabel"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PurpleLight}" />
                    <Label x:Name="ColorHintLabel"
                           FontSize="14"
                           TextColor="{StaticResource TextPrimary}"
                           LineBreakMode="WordWrap" />
                    <Button Text="保存长图"
                            Clicked="OnSaveImageClicked"
                            Style="{StaticResource OutlineButton}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
