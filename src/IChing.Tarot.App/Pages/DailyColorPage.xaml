<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.Tarot.App.Pages.DailyColorPage"
             Title="今日能量色"
             Shell.NavBarIsVisible="True"
             Shell.TabBarIsVisible="False"
             Background="{StaticResource PageGradient}">

    <ScrollView>
        <VerticalStackLayout Padding="20,28" Spacing="18">
            <Label Text="今日能量色"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Gold}" />

            <Border x:Name="ResultPanel"
                    Stroke="{StaticResource Purple}"
                    StrokeThickness="1"
                    Background="{StaticResource CardGradient}"
                    Padding="16"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="12">
                    <BoxView x:Name="ColorSwatch"
                             HeightRequest="120"
                             CornerRadius="12" />
                    <Label x:Name="ColorNameLabel"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PurpleLight}" />
                    <Label x:Name="ColorHintLabel"
                           FontSize="14"
                           TextColor="{StaticResource TextPrimary}"
                           LineBreakMode="WordWrap" />
                    <Button Text="保存长图"
                            Clicked="OnSaveImageClicked"
                            TextColor="{StaticResource Gold}"
                            BackgroundColor="{StaticResource SurfaceAlt}"
                            BorderColor="{StaticResource GoldDim}"
                            BorderWidth="1"
                            CornerRadius="24"
                            Padding="14,12" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
