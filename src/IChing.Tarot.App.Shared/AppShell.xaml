<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="IChing.Tarot.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:IChing.Tarot.App.Pages"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{StaticResource Surface}"
    Shell.ForegroundColor="{StaticResource Gold}"
    Shell.TitleColor="{StaticResource TextPrimary}"
    Shell.TabBarBackgroundColor="{StaticResource Surface}"
    Shell.TabBarForegroundColor="{StaticResource Gold}"
    Shell.TabBarUnselectedColor="{StaticResource Muted}"
    Shell.TabBarTitleColor="{StaticResource Gold}">

    <Tab Title="塔罗" Icon="tab_draw">
        <ShellContent Route="draw" ContentTemplate="{DataTemplate pages:DrawPage}" />
    </Tab>
    <Tab Title="探索" Icon="tab_explore">
        <ShellContent Route="explore" ContentTemplate="{DataTemplate pages:ExplorePage}" />
    </Tab>
    <Tab Title="设置" Icon="tab_settings">
        <ShellContent Route="settings" ContentTemplate="{DataTemplate pages:SettingsPage}" />
    </Tab>
</Shell>
