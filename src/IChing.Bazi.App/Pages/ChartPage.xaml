<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.Bazi.App.Pages.ChartPage"
             Title="八字排盘"
             Background="{StaticResource PageGradient}">

    <ScrollView x:Name="MainScroll">
        <VerticalStackLayout Padding="20,28" Spacing="18">
            <VerticalStackLayout Spacing="6">
                <Label Text="八字排盘"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Gold}" />
                <Label Text="本地 lunar-csharp · 规则概览"
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <Border Stroke="{StaticResource GoldDim}" StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}" Padding="16"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="出生时间" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <DatePicker x:Name="BirthDate" TextColor="{StaticResource TextPrimary}" />
                    <TimePicker x:Name="BirthTime" TextColor="{StaticResource TextPrimary}" />

                    <Label Text="性别（大运顺逆）" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <Picker x:Name="GenderPicker" Title="选择性别">
                        <Picker.Items>
                            <x:String>男</x:String>
                            <x:String>女</x:String>
                        </Picker.Items>
                    </Picker>

                    <Label Text="流年（可选）" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <Entry x:Name="FlowYearEntry"
                           Keyboard="Numeric"
                           Placeholder="@DateTime.Now.Year"
                           PlaceholderColor="{StaticResource Muted}"
                           TextColor="{StaticResource TextPrimary}"
                           BackgroundColor="{StaticResource SurfaceAlt}" />

                    <Label Text="关注点" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    <Entry x:Name="FocusEntry"
                           Placeholder="综合"
                           PlaceholderColor="{StaticResource Muted}"
                           TextColor="{StaticResource TextPrimary}"
                           BackgroundColor="{StaticResource SurfaceAlt}" />

                    <Button x:Name="CalcButton"
                            Text="排盘"
                            Clicked="OnCalculateClicked"
                            BackgroundColor="{StaticResource Gold}"
                            TextColor="{StaticResource Black}" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ResultPanel"
                    IsVisible="False"
                    Stroke="{StaticResource GoldDim}" StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}" Padding="16"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="SolarLabel" TextColor="{StaticResource TextPrimary}" FontSize="13" />
                    <Label x:Name="LunarLabel" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                    <Label x:Name="PillarsLabel"
                           TextColor="{StaticResource Gold}"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <Label x:Name="PatternLabel" TextColor="{StaticResource TextPrimary}" FontSize="13" />

                    <HorizontalStackLayout Spacing="10">
                        <Button x:Name="Tier0Button"
                                Text="概览解读"
                                Clicked="OnTier0Clicked"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                TextColor="{StaticResource TextPrimary}" />
                        <Button x:Name="Tier1Button"
                                Text="AI 解读"
                                Clicked="OnTier1Clicked"
                                BackgroundColor="{StaticResource Gold}"
                                TextColor="{StaticResource Black}" />
                    </HorizontalStackLayout>

                    <ActivityIndicator x:Name="InterpretBusy" IsVisible="False" IsRunning="False" Color="{StaticResource Gold}" />
                    <Label x:Name="SummaryLabel"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="13"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="ErrorLabel"
                   IsVisible="False"
                   TextColor="{StaticResource Danger}"
                   FontSize="13" />

            <Border x:Name="HistoryPanel"
                    IsVisible="False"
                    Stroke="{StaticResource GoldDim}" StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}" Padding="16"
                    StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="8">
                    <HorizontalStackLayout>
                        <Label Text="最近排盘" TextColor="{StaticResource Gold}" FontAttributes="Bold" HorizontalOptions="FillAndExpand" />
                        <Button Text="清空" Clicked="OnClearHistoryClicked" FontSize="12" BackgroundColor="Transparent" TextColor="{StaticResource Muted}" />
                    </HorizontalStackLayout>
                    <VerticalStackLayout x:Name="HistoryHost" Spacing="6" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
