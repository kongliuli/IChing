<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.App.Pages.BaziPage"
             Title="八字">
    <ScrollView>
        <VerticalStackLayout Padding="22,24,22,36"
                             Spacing="18"
                             MaximumWidthRequest="1120"
                             HorizontalOptions="Center">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <VerticalStackLayout Spacing="5">
                    <Label Text="八字排盘" Style="{StaticResource PageTitle}" />
                    <Label Text="天干地支 · 五行旺衰 · 用神取向"
                           Style="{StaticResource PageKicker}" />
                    <BoxView HeightRequest="2"
                             WidthRequest="56"
                             HorizontalOptions="Start"
                             Color="{StaticResource Cinnabar}" />
                </VerticalStackLayout>
                <Border Grid.Column="1"
                        WidthRequest="58"
                        HeightRequest="58"
                        Stroke="{StaticResource Cinnabar}"
                        StrokeThickness="2"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 8"
                        HorizontalOptions="End">
                    <Label Text="命"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Cinnabar}"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Border>
            </Grid>

            <Grid x:Name="ResponsiveGrid"
                  ColumnDefinitions="1.02*,0.98*"
                  RowDefinitions="Auto"
                  ColumnSpacing="16"
                  RowSpacing="16">
                <Border x:Name="InputPanel"
                        Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="出生信息" Style="{StaticResource SectionTitle}" />
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                            <Entry x:Name="YearEntry" Text="1990" Placeholder="年" Keyboard="Numeric" />
                            <Entry x:Name="MonthEntry" Grid.Column="1" Text="5" Placeholder="月" Keyboard="Numeric" />
                            <Entry x:Name="DayEntry" Grid.Row="1" Text="20" Placeholder="日" Keyboard="Numeric" />
                            <Entry x:Name="HourEntry" Grid.Row="1" Grid.Column="1" Text="10" Placeholder="时" Keyboard="Numeric" />
                            <Entry x:Name="MinuteEntry" Grid.Row="2" Text="0" Placeholder="分" Keyboard="Numeric" />
                            <Picker x:Name="GenderPicker" Grid.Row="2" Grid.Column="1" Title="性别">
                                <Picker.Items>
                                    <x:String>女</x:String>
                                    <x:String>男</x:String>
                                </Picker.Items>
                            </Picker>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Entry x:Name="CityEntry" Placeholder="城市，可空" />
                            <Entry x:Name="LongitudeEntry" Grid.Column="1" Placeholder="经度，可空" Keyboard="Numeric" />
                        </Grid>
                        <Entry x:Name="FocusEntry" Text="事业" Placeholder="关注点，如事业、关系、财运" />

                        <Button Text="排盘"
                                Clicked="OnCalculateClicked"
                                Style="{StaticResource PrimaryButton}" />
                        <Label x:Name="ErrorLabel"
                               IsVisible="False"
                               FontSize="12"
                               TextColor="{StaticResource Danger}" />
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="ResultPanel"
                        Grid.Column="1"
                        IsVisible="False"
                        Style="{StaticResource RaisedCard}">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="BaziTitleLabel"
                                       FontSize="23"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Cinnabar}" />
                                <Label x:Name="BaziSummaryLabel"
                                       FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    Padding="10,6"
                                    BackgroundColor="{StaticResource SurfaceAlt}"
                                    Stroke="{StaticResource StrokeSoft}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    VerticalOptions="Start">
                                <Label x:Name="DayMasterBadge"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Jade}" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                            <Border Padding="10" BackgroundColor="{StaticResource SurfaceAlt}" Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="年柱" Style="{StaticResource Caption}" HorizontalTextAlignment="Center" />
                                    <Label x:Name="YearPillarLabel" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" Padding="10" BackgroundColor="{StaticResource SurfaceAlt}" Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="月柱" Style="{StaticResource Caption}" HorizontalTextAlignment="Center" />
                                    <Label x:Name="MonthPillarLabel" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="2" Padding="10" BackgroundColor="{StaticResource SurfaceAlt}" Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="日柱" Style="{StaticResource Caption}" HorizontalTextAlignment="Center" />
                                    <Label x:Name="DayPillarLabel" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="3" Padding="10" BackgroundColor="{StaticResource SurfaceAlt}" Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="时柱" Style="{StaticResource Caption}" HorizontalTextAlignment="Center" />
                                    <Label x:Name="HourPillarLabel" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <Border Padding="12" BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource StrokeSoft}" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="用神与运势" Style="{StaticResource SectionTitle}" />
                                <Label x:Name="YongshenLabel" FontSize="14" TextColor="{StaticResource TextPrimary}" />
                                <Label x:Name="DaYunLabel" FontSize="12" TextColor="{StaticResource Muted}" />
                            </VerticalStackLayout>
                        </Border>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Button x:Name="InterpretButton"
                                    Text="AI 解读"
                                    IsEnabled="False"
                                    Clicked="OnInterpretClicked"
                                    Style="{StaticResource JadeButton}" />
                            <ActivityIndicator x:Name="InterpretIndicator"
                                               Grid.Column="1"
                                               IsRunning="False"
                                               IsVisible="False"
                                               Color="{StaticResource Jade}" />
                        </Grid>

                        <Border x:Name="InterpretationPanel"
                                IsVisible="False"
                                Padding="14"
                                BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource StrokeSoft}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                    <Label x:Name="InterpretStatusLabel"
                                           Style="{StaticResource Caption}"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center" />
                                    <Button x:Name="ExportButton"
                                            Grid.Column="1"
                                            Text="导出图片"
                                            IsVisible="False"
                                            Clicked="OnExportClicked"
                                            Style="{StaticResource PrimaryButton}" />
                                    <Button x:Name="FollowUpButton"
                                            Grid.Column="2"
                                            Text="追问"
                                            IsVisible="False"
                                            Clicked="OnFollowUpClicked"
                                            Style="{StaticResource JadeButton}" />
                                </Grid>
                                <Label x:Name="InterpretationLabel"
                                       FontSize="13"
                                       TextColor="{StaticResource TextPrimary}" />
                                <WebView x:Name="ReadingWebView"
                                         IsVisible="False"
                                         HeightRequest="760" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
