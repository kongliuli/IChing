<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.App.Pages.HistoryPage"
             Shell.NavBarIsVisible="False"
             Title="历史">
    <ScrollView>
        <VerticalStackLayout Padding="22,24,22,36"
                             Spacing="18"
                             MaximumWidthRequest="920"
                             HorizontalOptions="Center">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Spacing="5">
                    <Label Text="历史记录" Style="{StaticResource PageTitle}" />
                    <Label Text="本地保存 / 最近三十条"
                           Style="{StaticResource PageKicker}" />
                    <BoxView HeightRequest="2"
                             WidthRequest="56"
                             HorizontalOptions="Start"
                             Color="{StaticResource Cinnabar}" />
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="清空"
                        Clicked="OnClearClicked"
                        Style="{StaticResource SecondaryButton}"
                        VerticalOptions="Start" />
            </Grid>

            <Border x:Name="EmptyLabel"
                    Style="{StaticResource Card}">
                <Label Text="还没有记录。"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource Muted}" />
            </Border>

            <CollectionView x:Name="HistoryView"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10"
                                Style="{StaticResource Card}">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding DisplayLine}"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding Summary}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding Interpretation}"
                                       FontSize="12"
                                       TextColor="{StaticResource Jade}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
