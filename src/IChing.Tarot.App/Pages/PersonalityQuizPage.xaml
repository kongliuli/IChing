<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.Tarot.App.Pages.PersonalityQuizPage"
             Title="人格测评"
             Shell.NavBarIsVisible="True"
             Shell.TabBarIsVisible="False"
             Background="{StaticResource PageGradient}">

    <ScrollView x:Name="MainScroll">
        <VerticalStackLayout Padding="22,24,22,34"
                             Spacing="16"
                             MaximumWidthRequest="860"
                             HorizontalOptions="Center">
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="True"
                               IsVisible="True"
                               Color="{StaticResource Gold}" />

            <VerticalStackLayout x:Name="QuizHost" IsVisible="False" Spacing="16">
                <VerticalStackLayout Spacing="5">
                    <Label x:Name="TitleLabel" Style="{StaticResource PageTitle}" />
                    <Label x:Name="SubtitleLabel" Style="{StaticResource PageKicker}" />
                    <Label x:Name="DisclaimerLabel"
                           FontSize="11"
                           TextColor="{StaticResource Muted}"
                           LineBreakMode="WordWrap" />
                    <Label x:Name="ProgressLabel"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>

                <Border Style="{StaticResource TarotCardPanel}">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="QuestionLabel"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               LineBreakMode="WordWrap" />
                        <VerticalStackLayout x:Name="OptionsHost" Spacing="8" />
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="ResultPanel"
                        IsVisible="False"
                        Style="{StaticResource TarotCardPanel}">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="ResultCodeLabel"
                               FontSize="30"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gold}" />
                        <Label x:Name="ResultTitleLabel"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PurpleLight}" />
                        <Label x:Name="ResultSummaryLabel"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"
                               LineBreakMode="WordWrap" />
                        <WebView x:Name="ResultWebView"
                                 IsVisible="False"
                                 HeightRequest="480" />
                        <VerticalStackLayout x:Name="DimensionBarsHost" Spacing="10" />
                        <VerticalStackLayout x:Name="ResultSectionsHost" Spacing="4" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Text="保存长图"
                                    Clicked="OnSaveImageClicked"
                                    Style="{StaticResource OutlineButton}" />
                            <Button Grid.Column="1"
                                    Text="重新测试"
                                    Clicked="OnRestartClicked"
                                    Style="{StaticResource GoldButton}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
