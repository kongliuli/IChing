<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.App.Pages.HtmlPreviewPage"
             Title="分享预览">
    <Grid RowDefinitions="Auto,*"
          BackgroundColor="{StaticResource Background}">
        <Grid Padding="14,12"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="8"
              BackgroundColor="{StaticResource Surface}">
            <Label x:Name="TitleLabel"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Ink}"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="导出图片"
                    Clicked="OnExportClicked"
                    TextColor="{StaticResource White}"
                    BackgroundColor="{StaticResource Cinnabar}" />
            <Button Grid.Column="2"
                    Text="关闭"
                    Clicked="OnCloseClicked"
                    TextColor="{StaticResource Jade}"
                    BackgroundColor="{StaticResource SurfaceAlt}"
                    BorderColor="{StaticResource StrokeSoft}"
                    BorderWidth="1" />
        </Grid>
        <WebView x:Name="PreviewWebView"
                 Grid.Row="1" />
    </Grid>
</ContentPage>
