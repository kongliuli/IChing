<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IChing.App.Pages.FollowUpChatPage"
             Shell.NavBarIsVisible="False"
             Title="追问">
    <Grid RowDefinitions="*,Auto"
          Padding="18"
          RowSpacing="12"
          BackgroundColor="{StaticResource Background}">
        <ScrollView x:Name="ChatScroll">
            <VerticalStackLayout x:Name="ChatHost"
                                 Spacing="10"
                                 MaximumWidthRequest="860"
                                 HorizontalOptions="Center" />
        </ScrollView>
        <Border Grid.Row="1"
                Padding="10"
                MaximumWidthRequest="860"
                HorizontalOptions="Center"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource StrokeSoft}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry x:Name="QuestionEntry" Placeholder="继续追问，最多三轮" />
                <Button Grid.Column="1"
                        x:Name="SendButton"
                        Text="发送"
                        Clicked="OnSendClicked"
                        Style="{StaticResource JadeButton}" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>
